# ============================================================================
# Future AGI — self-hosted OSS configuration
# ============================================================================
# Copy this file to `.env` and replace every `CHANGEME` value below.
# The rest have sensible defaults and can be left alone for local evaluation.
#
#   cp .env.example .env
#   docker compose up
#
# For production deployments see docs/self-host.md.
# ============================================================================


# ----------------------------------------------------------------------------
# Stack mode
# ----------------------------------------------------------------------------
# Leave unset for the lightweight default (~12 containers): everything needed
# to run the app, with empty/stale data in analytics views.
#
# Set to `full` for the complete self-host (~22 containers). Adds the PeerDB
# CDC stack so transactional Postgres data streams into ClickHouse and the
# Observe / Trace analytics views populate.
# ----------------------------------------------------------------------------
# COMPOSE_PROFILES=full


# ----------------------------------------------------------------------------
# Secrets — CHANGEME before running in any non-local environment
# ----------------------------------------------------------------------------

# Django secret key. Generate with: openssl rand -hex 32
SECRET_KEY=CHANGEME-django-secret-key

# Postgres credentials (used by backend, worker, temporal)
PG_USER=futureagi
PG_PASSWORD=CHANGEME-postgres-password
PG_DB=futureagi

# MinIO root credentials (S3-compatible object storage)
MINIO_ROOT_USER=futureagi
MINIO_ROOT_PASSWORD=CHANGEME-minio-password

# App object storage. STORAGE_BACKEND selects how URLs are routed:
#   minio  self-hosted MinIO (the OSS default)
#   s3     AWS S3
#   gcs    GCS via S3-interop HMAC keys
# For "minio": S3_ENDPOINT_URL is the internal endpoint the backend uses,
# MINIO_URL is the browser-facing host baked into returned URLs.
STORAGE_BACKEND=minio
S3_ENDPOINT_URL=http://minio:9000
MINIO_URL=http://localhost:9005
UPLOAD_BUCKET_NAME=futureagi
S3_ACCESS_KEY=futureagi
S3_SECRET_KEY=CHANGEME-minio-password


# ----------------------------------------------------------------------------
# Host ports — override to avoid conflicts with other local services
# ----------------------------------------------------------------------------

FRONTEND_PORT=3000
BACKEND_PORT=8000
AGENTCC_GATEWAY_PORT=8090
SERVING_PORT=8080
CODE_EXECUTOR_PORT=8060
PG_PORT=5432
CH_HTTP_PORT=8123
CH_PORT=9000
# Set to true only for multi-node ClickHouse with shard/replica macros configured.
CH_USE_REPLICATED_ENGINES=false
REDIS_PORT=6379
MINIO_API_PORT=9005
MINIO_CONSOLE_PORT=9006
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8085
PEERDB_PORT=9900
PEERDB_UI_PORT=3001


# ----------------------------------------------------------------------------
# Backend runtime
# ----------------------------------------------------------------------------

# development | staging | prod
ENV_TYPE=development

# reCAPTCHA (set both and enable in production)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
VITE_GOOGLE_SITE_KEY=

# Mailgun (email delivery)
MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=
DEFAULT_FROM_EMAIL=
SERVER_EMAIL=

# Skip migrations + static collection on startup (dev only)
FAST_STARTUP=false

# Granian ASGI server
GRANIAN_WORKERS=1
GRANIAN_THREADS=2

# Feature toggles
ENABLE_GRPC=true
ENABLE_HTTP=true


# ----------------------------------------------------------------------------
# RabbitMQ
# ----------------------------------------------------------------------------

RABBITMQ_USER=user
RABBITMQ_PASSWORD=password
CELERY_BROKER_URL=amqp://user:password@rabbitmq:5672//


# ----------------------------------------------------------------------------
# Temporal worker
# ----------------------------------------------------------------------------

TEMPORAL_NAMESPACE=default

# Single worker polls all queues by default (saves resources for self-host).
# Set to false + use docker-compose.dev.yml for per-queue workers.
TEMPORAL_ALL_QUEUES=true

# Concurrency caps for the single all-queue worker
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=50
TEMPORAL_MAX_CONCURRENT_WORKFLOW_TASKS=50


# ----------------------------------------------------------------------------
# LLM gateway (agentcc)
# ----------------------------------------------------------------------------

# Shared secret between backend and gateway. Generate: openssl rand -hex 32
AGENTCC_INTERNAL_API_KEY=CHANGEME-gateway-shared-secret
AGENTCC_ADMIN_TOKEN=CHANGEME-gateway-admin-token

# Override gateway config (defaults to the shipped example). Copy
# agentcc-gateway/config.example.yaml to config.yaml, edit, then set:
# AGENTCC_CONFIG_PATH=agentcc-gateway/config.yaml


# ----------------------------------------------------------------------------
# LLM provider keys — leave blank unless you want to use that provider
# ----------------------------------------------------------------------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Vertex AI: not set up by default. The gateway reads provider config from
# agentcc-gateway/config.yaml, which can reference any ${ENV_VAR} from this
# file. To enable: copy config.example.yaml → config.yaml, uncomment the
# `vertex:` block, set AGENTCC_CONFIG_PATH=agentcc-gateway/config.yaml above,
# and add whatever env vars your config block references here. See
# INSTALLATION.md → "Vertex AI" for the recommended Bearer-token pattern and
# the warning about mounting Vertex_AI_Creds.json.


# ----------------------------------------------------------------------------
# Frontend build-time config (baked into the Vite bundle)
# ----------------------------------------------------------------------------

# VITE_HOST_API auto-derives to http://localhost:${BACKEND_PORT} when
# unset, so port-preflight auto-switching stays in sync. Uncomment + set
# only when pointing the bundle at a non-localhost backend (real deploy).
# VITE_HOST_API=http://localhost:8000
VITE_ENVIRONMENT=development


# ----------------------------------------------------------------------------
# Optional — Future AGI Cloud API (for EE-tier Cloud features only)
# Leave blank to run fully offline. See DEPLOYMENT-MODEL.md.
# ----------------------------------------------------------------------------

FUTURE_AGI_CLOUD_API_KEY=
FUTURE_AGI_CLOUD_API_URL=https://api.futureagi.com
