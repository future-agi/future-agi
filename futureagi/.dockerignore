*.sqlite3
*.db

# Docker files (not needed in image)
docker-compose*.yml
Dockerfile
Dockerfile.prod
.dockerignore

# Build and test artifacts
dist/
build/
*.egg-info/

# Static files (collected at runtime)
static/

